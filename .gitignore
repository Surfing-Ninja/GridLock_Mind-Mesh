.next/
**/.next/
out/
dist/
build/
.turbo/

# Raw and generated data
*.csv
*.parquet
*.duckdb
*.db
*.sqlite
*.sqlite3
data/raw/*
data/interim/*
data/processed/*
data/app/*
**/data/raw/*
**/data/interim/*
**/data/processed/*
