**/artifacts/metrics/*
**/artifacts/reports/*

# Logs and temporary files
*.log
*.zip
*.tar
*.tar.gz
logs/
tmp/
temp/

# Keep scaffold directories visible
!data/**/.gitkeep
!artifacts/**/.gitkeep
!**/data/**/.gitkeep
!**/artifacts/**/.gitkeep

